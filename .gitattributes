# Line ending normalization for the vdb-guardian monorepo.
#
# Goal: keep source files stored as LF in the repository and checked out as LF
# on every platform, so gofmt / golangci-lint / shell scripts behave identically
# on Linux, macOS, and Windows. Without this file, Git on Windows applies
# autocrlf=true and rewrites the working copy to CRLF, which makes `gofmt -l`,
# `make fmt-check`, and shell recipes in `Makefile` fail spuriously.
#
# After landing this file, run once to normalize already-tracked content:
#   git add --renormalize .
#   git commit -m "chore: normalize line endings to LF per .gitattributes"

# Default: let Git auto-detect text vs binary, store text as LF in the repo.
* text=auto eol=lf

# --- Source code ---
*.go         text eol=lf
*.py         text eol=lf
*.sh         text eol=lf
*.sql        text eol=lf

# --- Documentation ---
*.md         text eol=lf

# --- Configuration and manifests ---
*.yml        text eol=lf
*.yaml       text eol=lf
*.toml       text eol=lf
*.json       text eol=lf
*.lock       text eol=lf
*.mod        text eol=lf
*.sum        text eol=lf
go.mod       text eol=lf
go.sum       text eol=lf
uv.lock      text eol=lf

# --- Build and project files (no extension) ---
Makefile     text eol=lf
Dockerfile   text eol=lf
LICENSE      text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf
.editorconfig  text eol=lf
.golangci.yml  text eol=lf

# --- Binaries: never normalize ---
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.webp       binary
*.pdf        binary
*.zip        binary
*.tar        binary
*.tar.gz     binary
*.tgz        binary
*.gz         binary
*.so         binary
*.dll        binary
*.dylib      binary
*.exe        binary

# --- Linguist hints (GitHub language stats) ---
go.sum       linguist-generated=true
uv.lock      linguist-generated=true
testdata/**  linguist-vendored=true
